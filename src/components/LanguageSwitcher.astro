---
import { type Locale } from '../utils/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const currentPath = Astro.url.pathname;

// Strip locale prefix to get the shared base path.
const basePath = currentPath.replace(/^\/en/, '') || '/';
const idHref = basePath;
const enHref = `/en${basePath === '/' ? '' : basePath}`;
---

<div class="inline-flex items-center rounded-full border border-ink/15 text-sm overflow-hidden">
  <a
    href={idHref}
    aria-current={locale === 'id' ? 'true' : undefined}
    class:list={[
      'px-3 py-1.5 font-medium transition-colors',
      locale === 'id' ? 'bg-accent text-white' : 'text-ink hover:bg-accent-soft',
    ]}>ID</a
  >
  <a
    href={enHref}
    aria-current={locale === 'en' ? 'true' : undefined}
    class:list={[
      'px-3 py-1.5 font-medium transition-colors',
      locale === 'en' ? 'bg-accent text-white' : 'text-ink hover:bg-accent-soft',
    ]}>EN</a
  >
</div>
